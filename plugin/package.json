{
	"name": "obsidian-ai-agent",
	"version": "1.0.0",
	"description": "Right-sidebar AI agent for Obsidian with vault-aware retrieval, Claude/GPT/Gemini/Ollama support, and smart file editing.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run"
	},
	"keywords": ["obsidian", "ai", "agent", "llm", "claude", "gpt", "gemini", "ollama", "vault", "retrieval"],
	"license": "0-BSD",
	"devDependencies": {
		"vitest": "^2.0.0",
		"@types/node": "^20.0.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
